# Copy this to .env.local and fill in real values. Never commit .env.local.
# These are required env vars for the Pure Cleaning CRM project.

# ── Cloudflare ─────────────────────────────────────────────────────────────
# Used by wrangler CLI for deployments
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# ── Google Maps ────────────────────────────────────────────────────────────
# Used by the API worker for address geocoding (Bouncie GPS attribution)
# Set via: wrangler secret put GOOGLE_MAPS_API_KEY
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ── Bouncie OAuth ──────────────────────────────────────────────────────────
# BOUNCIE_CLIENT_ID is hardcoded as 'pure-cleaning-crm' (public OAuth client ID — not a secret)
# The following are set via: wrangler secret put BOUNCIE_CLIENT_SECRET
BOUNCIE_CLIENT_SECRET=your_bouncie_client_secret_here

# ── EmailJS (public-facing quote form) ─────────────────────────────────────
# Set in src/ React app if email sending is re-enabled
REACT_APP_EMAILJS_SERVICE_ID=your_emailjs_service_id_here
REACT_APP_EMAILJS_TEMPLATE_ID=your_emailjs_template_id_here
REACT_APP_EMAILJS_PUBLIC_KEY=your_emailjs_public_key_here

# ── Notes ──────────────────────────────────────────────────────────────────
# Worker secrets (GOOGLE_MAPS_API_KEY, BOUNCIE_CLIENT_SECRET) are set in
# Cloudflare Workers environment, NOT in this file. Use:
#   wrangler secret put SECRET_NAME
# KV namespace ID is in cloudflare-worker/wrangler.toml (not secret — it's a resource ID).
