# Pure Cleaning — local verification secrets
# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit it.

# Admin password for verify-deploy.js and verify-browser.js
# This is the same password you enter on the login screen.
# Once set, npm run deploy and npm run verify:browser run fully automatically.
ADMIN_PASSWORD=your_admin_password_here
