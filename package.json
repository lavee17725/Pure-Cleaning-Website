{
  "name": "fumero-pressure-washing",
  "homepage": "https://purecleaningpressurecleaning.com",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "emailjs-com": "^3.2.0",
    "react": "^18.2.0",
    "react-before-after-slider-component": "^1.1.6",
    "react-dom": "^18.2.0",
    "react-icons": "^4.8.0",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "CI= react-scripts build && node scripts/inject-jsonld.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy": "npm run build && npm run deploy:api && node scripts/verify-deploy.js && node scripts/verify-browser.js && git push origin main",
    "deploy:api": "npx wrangler deploy --config cloudflare-worker/wrangler.toml",
    "deploy:verify": "node scripts/verify-deploy.js",
    "verify:browser": "node scripts/verify-browser.js",
    "rules": "cat CLAUDE.md",
    "integrity": "node scripts/integrity-check.js",
    "integrity:fix": "node scripts/integrity-check.js --auto-fix",
    "typecheck": "node scripts/typecheck.js",
    "secret-scan": "node scripts/secret-scan.js",
    "preview": "npm run build && wrangler dev",
    "prepare": "husky"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "gh-pages": "^6.3.0",
    "husky": "^9.1.7",
    "playwright": "^1.59.1",
    "wrangler": "^4.88.0"
  }
}
